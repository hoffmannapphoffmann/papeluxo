# ============================================
# Papeluxo - Configuração de Ambiente
# ============================================
# Copie este arquivo para .env e preencha as credenciais
# cp .env.example .env
# ============================================

# Domínio (produção - alterar conforme necessário)
DOMAIN=seu-dominio.com.br
LETSENCRYPT_EMAIL=seu-email@exemplo.com.br

# n8n autenticação
N8N_USER=admin
N8N_PASSWORD=coloque-uma-senha-forte-aqui

# n8n database
N8N_DB_USER=n8n
N8N_DB_PASSWORD=coloque-uma-senha-forte-aqui
N8N_DB_NAME=n8n

# WAHA (WhatsApp Gateway)
WAHA_API_KEY=coloque-uma-chave-api-forte-aqui
WAHA_SESSION=default

# Google Gemini (IA)
GEMINI_API_KEY=sua-chave-gemini-aqui
GEMINI_MODEL=gemini-2.5-flash

# Tray Commerce API
TRAY_API_URL=coloque-sua-tray-api-url-aqui
TRAY_CONSUMER_KEY=sua-consumer-key-tray-aqui
TRAY_CONSUMER_SECRET=sua-consumer-secret-tray-aqui
TRAY_ACCESS_TOKEN=seu-access-token-tray-aqui
TRAY_REFRESH_TOKEN=seu-refresh-token-tray-aqui

# Atendente humano (transferência)
NUMERO_ATENDENTE=coloque-o-numero-do-atendente-aqui
